# ── Server ─────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=9999
DEBUG_MODE=false

# ── MediaMTX ───────────────────────────────────────────────────────────────
MEDIAMTX_HOST=127.0.0.1
MEDIAMTX_PORT=8554

# ── External IP (Docker only) ──────────────────────────────────────────────
# Set this to the host machine's IP so the Web UI and ONVIF responses advertise
# an IP that NVRs can actually reach (otherwise they get the container's bridge IP).
# Example: EXTERNAL_IP=192.168.1.100
EXTERNAL_IP=

# ── Upload & disk limits ───────────────────────────────────────────────────
# Largest single upload (rejected with HTTP 413 if exceeded).
MAX_UPLOAD_MB=500
# Largest transcoded output. Transcode is aborted and the file is deleted if exceeded.
MAX_VIDEO_SIZE_MB=1024
# Hourly orphan scanner for data/videos and data/snapshots.
DATA_CLEANUP_ENABLED=true
DATA_CLEANUP_INTERVAL_HOURS=1
DATA_ORPHAN_GRACE_SECONDS=300

# ── Reliability ────────────────────────────────────────────────────────────
# Auto-restart dead FFmpeg / ONVIF subprocesses.
WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL_SECONDS=15
WATCHDOG_MAX_RESTARTS=5

# ── ONVIF dispatcher (advanced) ────────────────────────────────────────────
# Collapse N onvif_server.py subprocesses into a single in-process Flask
# served by werkzeug-per-port. Saves ~25 MB RSS per camera. Opt-in.
ONVIF_DISPATCHER_ENABLED=false

# ── Macvlan (independent IP + MAC per camera) ══════════════════════════════
# Each mock camera gets its own IP and MAC on the LAN so NVRs discover them
# as separate devices.
#
# Requirements:
#   - Linux host only (not supported on macOS Docker Desktop)
#   - Host and NVR must be on the same physical network segment
#
# Setup:
#   1. Run ARP isolation on the host once:
#        sudo bash scripts/setup-macvlan-host.sh eth0
#   2. Start with the macvlan overlay:
#        docker compose -f docker-compose.yml -f docker-compose.macvlan.yml up -d
#
# MACVLAN_ENABLED=true
# MACVLAN_PARENT=eth0            # Host physical NIC (e.g. eth0, ens3)

# IP assignment — choose one:

# Option A (recommended): router assigns IPs via DHCP, no manual range needed.
# MACVLAN_DHCP=true

# Option B: static IP pool — ensure range does not overlap with router DHCP.
# MACVLAN_DHCP=false
# MACVLAN_SUBNET=192.168.0.0/24
# MACVLAN_GATEWAY=192.168.0.1
# MACVLAN_IP_START=192.168.0.201
# MACVLAN_IP_END=192.168.0.250

# MACVLAN_PARENT_IFACE=eth0      # Interface name inside the container (auto-detected if omitted)
