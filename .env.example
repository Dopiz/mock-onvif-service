# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=9999
DEBUG_MODE=true

# MediaMTX Configuration
MEDIAMTX_HOST=127.0.0.1
MEDIAMTX_PORT=8554

# External IP (for external access, used in Docker)
# Set this to your host machine's IP address to ensure:
# - Web UI displays correct RTSP/ONVIF URLs (instead of container's internal IP)
# - ONVIF server tells NVR platforms the correct IP for stream access
# Example: EXTERNAL_IP=192.168.1.100
EXTERNAL_IP=

# === Macvlan Networking (每個 camera 獨立 IP + MAC) ===
# Linux only — not supported on macOS Docker Desktop.
#
# Prerequisites:
#   1. Run ARP isolation on the host (required, prevents ARP spoofing):
#        sudo bash scripts/setup-macvlan-host.sh eth0
#   2. Start with the macvlan overlay:
#        docker compose -f docker-compose.yml -f docker-compose.macvlan.yml up -d
#
# MACVLAN_ENABLED=true
# MACVLAN_PARENT=eth0            # Host physical NIC (parent for macvlan)
# MACVLAN_PARENT_IFACE=eth1      # Interface name inside the container

# IP assignment mode — choose one:

# Option A (recommended): let the router assign IPs via DHCP
# MACVLAN_DHCP=true

# Option B: static IP pool (ensure range doesn't overlap with router DHCP)
# MACVLAN_DHCP=false
# MACVLAN_SUBNET=192.168.0.0/24
# MACVLAN_GATEWAY=192.168.0.1
# MACVLAN_IP_START=192.168.0.201
# MACVLAN_IP_END=192.168.0.250
